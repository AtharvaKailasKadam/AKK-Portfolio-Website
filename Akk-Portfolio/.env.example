# EmailJS Configuration
# Get these values from https://www.emailjs.com/

# Your EmailJS service ID (e.g., "service_xxxxxxxxxxxxx")
VITE_EMAIL_SERVICE_ID=your_service_id_here

# Your EmailJS template ID (e.g., "template_xxxxxxxxxxxxx")
VITE_EMAIL_TEMPLATE_ID=your_template_id_here

# Your EmailJS public API key (e.g., "xxxxxxxxxxxxxxxxxxxxx")
VITE_EMAIL_PUBLIC_KEY=your_public_key_here
